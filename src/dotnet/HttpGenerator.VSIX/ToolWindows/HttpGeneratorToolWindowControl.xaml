<DataTemplate xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
              xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
              xmlns:styles="clr-namespace:Microsoft.VisualStudio.Shell;assembly=Microsoft.VisualStudio.Shell.15.0"
              xmlns:colors="clr-namespace:Microsoft.VisualStudio.PlatformUI;assembly=Microsoft.VisualStudio.Shell.15.0">
    <DataTemplate.Resources>
        <Style TargetType="Button" BasedOn="{StaticResource {x:Static styles:VsResourceKeys.ButtonStyleKey}}" />
        <Style TargetType="CheckBox" BasedOn="{StaticResource {x:Static styles:VsResourceKeys.CheckBoxStyleKey}}" />
        <Style TargetType="TextBox" BasedOn="{StaticResource {x:Static styles:VsResourceKeys.TextBoxStyleKey}}" />
        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource {x:Static colors:EnvironmentColors.ToolWindowTextBrushKey}}" />
        </Style>
    </DataTemplate.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="12">
            <TextBlock FontWeight="Bold"
                       FontSize="16"
                       Text="Generation settings" />

            <CheckBox Margin="0,12,0,0"
                      IsChecked="{Binding UseSiblingHttpFilesFolder}">
                Write output to a sibling HttpFiles folder
            </CheckBox>

            <TextBlock Margin="0,4,0,0"
                       Opacity="0.8"
                       Text="Clear this option to write generated files beside the selected OpenAPI document." />

            <TextBlock Margin="0,12,0,0"
                       Text="Base URL override" />
            <TextBox Text="{Binding BaseUrl, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

            <TextBlock Margin="0,12,0,0"
                       Text="Content type override" />
            <TextBox Text="{Binding ContentType, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

            <CheckBox Margin="0,12,0,0"
                      IsChecked="{Binding GenerateMultipleFiles}">
                Generate one .http file per request
            </CheckBox>

            <Button Margin="0,12,0,0"
                    HorizontalAlignment="Left"
                    Command="{Binding SaveSettingsCommand}"
                    Content="Save settings"
                    MinWidth="120" />

            <Separator Margin="0,16,0,16" />

            <TextBlock FontWeight="Bold"
                       FontSize="16"
                       Text="Background activity" />

            <TextBlock Margin="0,12,0,0"
                       FontWeight="SemiBold"
                       Text="{Binding StatusHeadline}" />

            <TextBlock Margin="0,6,0,0"
                       Text="{Binding ActiveJobSummary}" />

            <TextBox Margin="0,12,0,0"
                     AcceptsReturn="True"
                     Height="220"
                     IsReadOnly="True"
                     Text="{Binding StatusDetails, Mode=OneWay}"
                     TextWrapping="Wrap"
                     VerticalScrollBarVisibility="Auto" />

            <Button Margin="0,12,0,0"
                    HorizontalAlignment="Left"
                    Command="{Binding OpenOutputFolderCommand}"
                    Content="Open output folder"
                    IsEnabled="{Binding CanOpenOutputFolder}"
                    MinWidth="140" />
        </StackPanel>
    </ScrollViewer>
</DataTemplate>
